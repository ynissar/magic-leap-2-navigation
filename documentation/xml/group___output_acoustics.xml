      <memberdef kind="function" id="group___output_acoustics_1gad30ca6c72be37550687df1d9e35b2bd6" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="group___platform_1ga0b35b4ae5f4bf20dda1efd1554d58796" kindref="member">MLResult</ref></type>
        <definition>MLResult MLAudioResetAcousticScene</definition>
        <argsstring>()</argsstring>
        <name>MLAudioResetAcousticScene</name>
        <briefdescription>
<para>Resets the Acoustic Scene. </para>
        </briefdescription>
        <detaileddescription>
<para>Each client of this audio API is automatically assigned an Acoustic Scene that specifies the acoustic behaviors of that client&apos;s spatial audio content. An Acoustic Scene can be modified and customized by calling functions in the ACOUSTICS section of this audio API. This function resets the caller&apos;s Acoustic Scene to its initial default state.</para>
<para><simplesect kind="par"><title>API Level:\n 20</title><para></para>
</simplesect>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>MLResult_Ok</parametername>
</parameternamelist>
<parameterdescription>
<para>Successfully reset the Acoustic Scene. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_UnspecifiedFailure</parametername>
</parameternamelist>
<parameterdescription>
<para>Internal error. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLAudioResult_HandleNotFound</parametername>
</parameternamelist>
<parameterdescription>
<para>No custom scene exists for client.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<xrefsect id="permissions_1_permissions000042"><xreftitle>Required Permissions</xreftitle><xrefdescription><para>None </para>
</xrefdescription></xrefsect></para>
        </detaileddescription>
