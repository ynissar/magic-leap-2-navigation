        <definition>MLResult MLAudioGetBufferedOutputDefaults</definition>
        <argsstring>(uint32_t channel_count, uint32_t samples_per_second, float max_pitch_change, MLAudioBufferFormat *out_format, uint32_t *out_recommended_size_in_bytes, uint32_t *out_min_size_in_bytes)</argsstring>
        <name>MLAudioGetBufferedOutputDefaults</name>
        <param>
          <type>uint32_t</type>
          <declname>channel_count</declname>
        </param>
        <param>
          <type>uint32_t</type>
          <declname>samples_per_second</declname>
        </param>
