      <memberdef kind="function" id="group___output_control_1ga7d64b4f6b97c1c27cbdd3cf98ff601f6" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="group___platform_1ga0b35b4ae5f4bf20dda1efd1554d58796" kindref="member">MLResult</ref></type>
        <definition>MLResult MLAudioStartSound</definition>
        <argsstring>(MLHandle handle)</argsstring>
        <name>MLAudioStartSound</name>
        <param>
          <type><ref refid="group___platform_1gad436878dff21489f44eaeddc7585681d" kindref="member">MLHandle</ref></type>
          <declname>handle</declname>
        </param>
        <briefdescription>
<para>Starts playback for a sound output. </para>
        </briefdescription>
        <detaileddescription>
<para>Calling this function on a playing sound has no effect and returns success. Calling this function on a paused sound will start the sound output from the beginning. When starting playback for a buffered output stream, the &quot;out_frames_played&quot; counter retrieved by calling MLAudioGetBufferedOutputFramesPlayed is reset to 0.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">handle</parametername>
</parameternamelist>
<parameterdescription>
<para>MLHandle of the sound output.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>MLResult_Ok</parametername>
</parameternamelist>
<parameterdescription>
<para>Sound output is started, or continues if already playing. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_UnspecifiedFailure</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed due to an unknown error. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLAudioResult_HandleNotFound</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed due to a missing handle. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLAudioResult_NotImplemented</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed because feature has not been implemented yet. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLAudioResult_ResourceDiscarded</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed because file was closed. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLAudioResult_ResourceNotFound</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed because resource was not found.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<xrefsect id="permissions_1_permissions000018"><xreftitle>Required Permissions</xreftitle><xrefdescription><para>None </para>
</xrefdescription></xrefsect></para>
        </detaileddescription>
