        <definition>MLResult MLAudioGetBufferedInputDefaults</definition>
        <argsstring>(uint32_t channel_count, uint32_t samples_per_second, MLAudioBufferFormat *out_format, uint32_t *out_recommended_size_in_bytes, uint32_t *out_min_size_in_bytes)</argsstring>
