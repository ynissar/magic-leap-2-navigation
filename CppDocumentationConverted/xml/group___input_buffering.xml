        <definition>MLResult MLAudioGetBufferedInputLatency</definition>
        <argsstring>(MLHandle handle, float *out_latency_in_msec)</argsstring>
        <name>MLAudioGetBufferedInputLatency</name>
        <param>
          <type><ref refid="group___platform_1gad436878dff21489f44eaeddc7585681d" kindref="member">MLHandle</ref></type>
          <declname>handle</declname>
        </param>
        <param>
          <type>float *</type>
          <declname>out_latency_in_msec</declname>
        </param>
        <briefdescription>
<para>Queries the latency for a sound input. </para>
        </briefdescription>
        <detaileddescription>
<para>The latency for a sound input is the time between when a sound is picked up at the microphone and when the corresponding audio becomes available via a call to MLAudioGetInputBuffer.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">handle</parametername>
</parameternamelist>
<parameterdescription>
<para>MLHandle of the sound input. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="out">out_latency_in_msec</parametername>
</parameternamelist>
<parameterdescription>
<para>Retrieved latency in milliseconds.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
