<parametername>MLResult_InvalidParam</parametername>
</parameternamelist>
<parameterdescription>
<para>NULL passed for ml_time. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_UnspecifiedFailure</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed to convert timespec with unknown error.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
