        <definition>MLResult MLAudioGetInputState</definition>
        <argsstring>(MLHandle handle, MLAudioState *out_state)</argsstring>
        <name>MLAudioGetInputState</name>
        <param>
          <type><ref refid="group___platform_1gad436878dff21489f44eaeddc7585681d" kindref="member">MLHandle</ref></type>
          <declname>handle</declname>
