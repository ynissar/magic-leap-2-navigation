        <definition>MLResult MLZIIsServerConfigured</definition>
        <argsstring>(bool *out_is_configured)</argsstring>
        <name>MLZIIsServerConfigured</name>
        <param>
          <type>bool *</type>
          <declname>out_is_configured</declname>
        </param>
        <briefdescription>
<para>Checks to see if the Zero Iteration server is running and configured properly to use by a host application. </para>
        </briefdescription>
        <detaileddescription>
<para><simplesect kind="par"><title>API Level:\n 20</title><para></para>
</simplesect>
<parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="out">out_is_configured</parametername>
</parameternamelist>
<parameterdescription>
<para>Pointer to a bool indicating whether the ZI server is running and is configured properly.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>MLResult_InvalidParam</parametername>
</parameternamelist>
<parameterdescription>
<para>is_configured parameter is not valid (null). </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_Ok</parametername>
</parameternamelist>
<parameterdescription>
<para>If query was successful. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_Timeout</parametername>
</parameternamelist>
<parameterdescription>
<para>The ZI server could not be reached. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_UnspecifiedFailure</parametername>
</parameternamelist>
<parameterdescription>
<para>There was an unknown error submitting the query.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<xrefsect id="permissions_1_permissions000737"><xreftitle>Required Permissions</xreftitle><xrefdescription><para>None </para>
</xrefdescription></xrefsect></para>
