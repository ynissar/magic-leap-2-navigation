        <definition>MLResult MLOcclusionGetLatestMesh</definition>
        <argsstring>(MLHandle handle, const MLOcclusionMeshQuery *mesh_query, MLOcclusionMesh *out_mesh_data)</argsstring>
        <name>MLOcclusionGetLatestMesh</name>
        <param>
          <type><ref refid="group___platform_1gad436878dff21489f44eaeddc7585681d" kindref="member">MLHandle</ref></type>
