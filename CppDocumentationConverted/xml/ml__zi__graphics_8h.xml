</parameternamelist>
<parameterdescription>
<para>If query was successful. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_UnspecifiedFailure</parametername>
</parameternamelist>
<parameterdescription>
<para>There was an unknown error submitting the query.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
