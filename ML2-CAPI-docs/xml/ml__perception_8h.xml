        <type><ref refid="group___platform_1ga0b35b4ae5f4bf20dda1efd1554d58796" kindref="member">MLResult</ref></type>
        <definition>MLResult MLPerceptionGetPredictedSnapshot</definition>
        <argsstring>(MLTime timestamp, MLSnapshot **out_snapshot)</argsstring>
        <name>MLPerceptionGetPredictedSnapshot</name>
        <param>
          <type><ref refid="group___common_1ga39ed24b20d4477f2d684e554df0e582f" kindref="member">MLTime</ref></type>
