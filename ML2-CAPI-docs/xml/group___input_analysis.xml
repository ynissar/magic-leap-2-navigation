      <memberdef kind="function" id="group___input_analysis_1ga96b4ae2ac0e8a31e251e85320f7a62ee" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="group___platform_1ga0b35b4ae5f4bf20dda1efd1554d58796" kindref="member">MLResult</ref></type>
        <definition>MLResult MLAudioBeginSpectralAnalysisFromMicCapture</definition>
        <argsstring>(MLAudioSpectralAnalysisTarget target, MLAudioSpectralAnalysisCallback callback, void *context, MLHandle *out_handle)</argsstring>
        <name>MLAudioBeginSpectralAnalysisFromMicCapture</name>
        <param>
          <type><ref refid="group___def_analysis_1gaa8f82371e07f2f8513a2154bbdd263fd" kindref="member">MLAudioSpectralAnalysisTarget</ref></type>
          <declname>target</declname>
        </param>
