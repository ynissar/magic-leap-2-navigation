        <type><ref refid="group___platform_1ga0b35b4ae5f4bf20dda1efd1554d58796" kindref="member">MLResult</ref></type>
        <definition>MLResult MLAudioSetMicMute</definition>
        <argsstring>(bool is_muted)</argsstring>
        <name>MLAudioSetMicMute</name>
        <param>
          <type>bool</type>
          <declname>is_muted</declname>
        </param>
        <briefdescription>
<para>Sets the global input mute state for all input streams. </para>
        </briefdescription>
        <detaileddescription>
<para>The global input mute applies to all input streams, including microphones, Virtual Capture and Mixed Capture. Any app with capture privileges can set it, and it will apply for all apps.</para>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">is_muted</parametername>
</parameternamelist>
<parameterdescription>
<para>If true, capture streams will be muted globally.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<parameterlist kind="retval"><parameteritem>
<parameternamelist>
<parametername>MLResult_Ok</parametername>
</parameternamelist>
<parameterdescription>
<para>Successfully set the value. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_PermissionDenied</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed due to lack of permission. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLResult_UnspecifiedFailure</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed due to an unknown error. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>MLAudioResult_NotImplemented</parametername>
</parameternamelist>
<parameterdescription>
<para>Failed because feature has not been implemented yet.</para>
</parameterdescription>
</parameteritem>
</parameterlist>
<xrefsect id="permissions_1_permissions000102"><xreftitle>Required Permissions</xreftitle><xrefdescription><para>android.permission.RECORD_AUDIO (protection level: dangerous) </para>
</xrefdescription></xrefsect></para>
