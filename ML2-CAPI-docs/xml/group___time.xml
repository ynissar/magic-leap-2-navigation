        <definition>MLResult MLTimeConvertMLTimeToSystemTime</definition>
        <argsstring>(MLTime ml_time, struct timespec *out_timespec_time)</argsstring>
        <name>MLTimeConvertMLTimeToSystemTime</name>
        <param>
          <type><ref refid="group___common_1ga39ed24b20d4477f2d684e554df0e582f" kindref="member">MLTime</ref></type>
