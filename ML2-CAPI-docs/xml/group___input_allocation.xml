        <definition>MLResult MLAudioCreateInputFromMicCapture</definition>
        <argsstring>(MLAudioMicCaptureType mic_capture_type, const MLAudioBufferFormat *format, uint32_t buffer_size_in_bytes, MLAudioBufferCallback callback, void *context, MLHandle *out_handle)</argsstring>
