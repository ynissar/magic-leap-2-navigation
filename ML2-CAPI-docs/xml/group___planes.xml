          <name>MLPlanesQueryFlag_OrientToGravity</name>
          <initializer>= 1 &lt;&lt; 3</initializer>
          <briefdescription>
<para>For non-horizontal planes, setting this flag will result in the top of the plane rectangle being perpendicular to gravity. </para>
          </briefdescription>
          <detaileddescription>
          </detaileddescription>
        </enumvalue>
