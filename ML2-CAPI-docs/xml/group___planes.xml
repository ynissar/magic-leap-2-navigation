          <name>MLPlanesQueryFlag_Horizontal</name>
          <initializer>= 1 &lt;&lt; 1</initializer>
          <briefdescription>
          </briefdescription>
          <detaileddescription>
<para>Include planes whose normal is parallel to gravity. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group___planes_1ggad84e5ef87b8e50b35ce8720d252ad8eead2345dd555c0d0587fbfef3d575d76c6" prot="public">
          <name>MLPlanesQueryFlag_Arbitrary</name>
          <initializer>= 1 &lt;&lt; 2</initializer>
          <briefdescription>
          </briefdescription>
          <detaileddescription>
<para>Include planes with arbitrary normals. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="group___planes_1ggad84e5ef87b8e50b35ce8720d252ad8eeaa6fc64fb64939159ce9075ab9495a74a" prot="public">
          <name>MLPlanesQueryFlag_AllOrientations</name>
          <initializer>= MLPlanesQueryFlag_Vertical |
                                       MLPlanesQueryFlag_Horizontal |
                                       MLPlanesQueryFlag_Arbitrary</initializer>
          <briefdescription>
          </briefdescription>
          <detaileddescription>
<para>Include all plane orientations. </para>
          </detaileddescription>
        </enumvalue>
