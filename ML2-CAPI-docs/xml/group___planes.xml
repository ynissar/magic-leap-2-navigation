          <name>MLPlanesQueryFlag_Vertical</name>
          <initializer>= 1 &lt;&lt; 0</initializer>
          <briefdescription>
          </briefdescription>
          <detaileddescription>
<para>Include planes whose normal is perpendicular to gravity. </para>
          </detaileddescription>
        </enumvalue>
