          <name>MLPlanesQueryFlag_Inner</name>
          <initializer>= 1 &lt;&lt; 4</initializer>
          <briefdescription>
<para>If this flag is set, inner planes will be returned; if it is not set, outer planes will be returned. </para>
          </briefdescription>
          <detaileddescription>
          </detaileddescription>
        </enumvalue>
